{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cầm Đồ 55",
  "version": "0.1.15",
  "identifier": "com.hoangtat.cam-do-55",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Cầm Đồ 55",
        "width": 1100,
        "height": 750,
        "center": true,
        "focus": true,
        "x": 0,
        "y": 0
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "telegram-agent"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
